# ── Spotify API ──────────────────────────────────────────
# Get your Client ID at: https://developer.spotify.com/dashboard
# Create an app → Settings → copy the Client ID
# Add Redirect URI: echo://auth/callback
EXPO_PUBLIC_SPOTIFY_CLIENT_ID=

# ── Backend URL ──────────────────────────────────────────
# Where the FastAPI server runs
# Android emulator → http://10.0.2.2:8000
# iOS simulator     → http://localhost:8000
# Physical device   → http://<your-lan-ip>:8000
EXPO_PUBLIC_BACKEND_URL=http://10.0.2.2:8000

# ── Ticketmaster API ─────────────────────────────────────
# Get your key at: https://developer.ticketmaster.com/
# This goes into echo-backend/.env — NOT here
# Listed here just so you know both exist
# TICKETMASTER_API_KEY=   ← put this in echo-backend/.env
